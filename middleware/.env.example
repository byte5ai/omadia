# ----------------------------------------------------------------------------
# Middleware configuration — local-first sub-agent runtime
# Copy to `.env` and fill in the values you need.
# ----------------------------------------------------------------------------

# --- Anthropic SDK (REQUIRED) -----------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ORCHESTRATOR_MODEL=claude-opus-4-7
ORCHESTRATOR_MAX_TOKENS=4096

# --- Sub-agent runtime ------------------------------------------------------
# Each domain (accounting, hr, confluence) runs as a local tool-loop in this
# process. Skills live under SKILLS_DIR, tools are wired directly to the
# Odoo / Confluence clients below. Set SUB_AGENT_MODEL to a cheaper model
# (e.g. claude-sonnet-4-6 or claude-haiku-4-5-20251001) to keep costs down
# while the orchestrator stays on Opus.
SUB_AGENT_MODEL=claude-opus-4-7
SUB_AGENT_MAX_TOKENS=4096
SUB_AGENT_MAX_ITERATIONS=16
SKILLS_DIR=../skills

# --- Odoo credentials (required for odoo-accounting + odoo-hr sub-agents) ---
# When all four are set, both Odoo sub-agents are enabled. Creds stay
# in-process — they never reach any model prompt.
ODOO_URL=https://odoo.byte5.de
ODOO_DB=
ODOO_LOGIN=
ODOO_API_KEY=
ODOO_PROXY_MAX_BYTES=500000

# --- Confluence credentials (required for confluence-playbook sub-agent) ----
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_BASE_URL=https://byte5.atlassian.net/wiki
CONFLUENCE_SPACE_KEY=HOME
CONFLUENCE_PROXY_MAX_BYTES=200000

# --- Persistence ------------------------------------------------------------
MEMORY_DIR=./.memory
MEMORY_SEED_DIR=./seed/memory
# missing | overwrite | skip
MEMORY_SEED_MODE=missing

# --- Knowledge graph (Neon Postgres) ----------------------------------------
# When DATABASE_URL is set, the middleware persists the knowledge + agentic
# graph in Neon (schema auto-migrates on startup). Leave empty to fall back
# to the in-memory store (tests + zero-config dev).
# Create a project at neon.tech → copy the pooled connection string.
DATABASE_URL=
# Optional — tag every node/edge with a tenant scope. Default: `default`.
GRAPH_TENANT_ID=byte5

# --- Admin endpoint (optional) ----------------------------------------------
# When set, mounts /api/admin for memory inspection/maintenance.
ADMIN_TOKEN=

# --- Dev endpoints (LOCAL ONLY) ---------------------------------------------
# Mounts unauthenticated /api/dev/memory for the Next.js dev UI. Must stay
# OFF in any deployed environment.
# DEV_ENDPOINTS_ENABLED=true

# --- Microsoft Bot Framework / Teams (optional) -----------------------------
# Leave empty for local HTTP-only dev via /api/chat.
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TYPE=MultiTenant
MICROSOFT_APP_TENANT_ID=

# --- Runtime ----------------------------------------------------------------
MAX_TOOL_ITERATIONS=12
PORT=3979

# --- Diagram rendering (Kroki + Tigris/MinIO) -------------------------------
# When all of KROKI_BASE_URL, DIAGRAM_URL_SECRET, BUCKET_NAME and
# AWS_ENDPOINT_URL_S3 are set, the orchestrator exposes the `render_diagram`
# tool and the middleware serves signed PNG URLs at /diagrams/<key>.
# Defaults below match `compose.yml` in the repo root (local dev).
KROKI_BASE_URL=http://localhost:8765
# openssl rand -hex 32   (32+ random bytes; never share; rotate on leak)
DIAGRAM_URL_SECRET=
# Base URL that Teams clients fetch signed image URLs from. For local dev this
# is the middleware on :3979; on Fly it's https://<app>.fly.dev.
DIAGRAM_PUBLIC_BASE_URL=http://localhost:3979

# Object-storage credentials. Locally filled by compose.yml's MinIO (see values
# below). On Fly these four are auto-provisioned by `fly storage create`.
BUCKET_NAME=diagrams
AWS_ENDPOINT_URL_S3=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# --- Topic detection (Ollama sidecar for in-tenant embeddings) --------------
# When OLLAMA_BASE_URL is set, the Teams bot classifies every follow-up to
# decide "same topic / new topic / ask the user". Compose.yml provides the
# local sidecar on :11434; on Fly point this at http://odoo-bot-ollama.internal:11434.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
TOPIC_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
# Similarity thresholds — tune carefully. Above upper = auto continue,
# below lower = auto reset, in-between = escalate to Haiku then ask.
TOPIC_UPPER_THRESHOLD=0.55
TOPIC_LOWER_THRESHOLD=0.15

# --- Odoo entity sync (proactive graph population) --------------------------
# When enabled, the middleware pulls core business entities (res.partner,
# hr.employee, hr.department, account.journal) into the knowledge graph on
# startup and every ODOO_ENTITY_SYNC_INTERVAL_HOURS. HR red-line fields are
# never requested — only name + public-domain metadata.
ODOO_ENTITY_SYNC_ENABLED=false
ODOO_ENTITY_SYNC_INTERVAL_HOURS=6
ODOO_ENTITY_SYNC_PAGE_SIZE=100
ODOO_ENTITY_SYNC_MAX_PER_MODEL=5000

# --- Confluence entity sync (analog to Odoo sync) ---------------------------
CONFLUENCE_ENTITY_SYNC_ENABLED=false
CONFLUENCE_ENTITY_SYNC_INTERVAL_HOURS=12
CONFLUENCE_ENTITY_SYNC_PAGE_SIZE=50
CONFLUENCE_ENTITY_SYNC_MAX_PAGES=2000
