# ----------------------------------------------------------------------------
# Omadia middleware configuration
# Copy to `.env` and fill in the values you need.
#
# Channel-, integration-, and agent-specific credentials (e.g. Odoo, Teams,
# Confluence) live inside their plugin packages and are configured through
# the admin UI's plugin setup form — NOT here.
# ----------------------------------------------------------------------------

# --- Anthropic SDK (REQUIRED) -----------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ORCHESTRATOR_MODEL=claude-opus-4-7
ORCHESTRATOR_MAX_TOKENS=4096

# --- Sub-agent runtime ------------------------------------------------------
# Sub-agents run as local tool-loops in this process. Set SUB_AGENT_MODEL to
# a cheaper model (e.g. claude-sonnet-4-6 or claude-haiku-4-5) to keep costs
# down while the orchestrator stays on Opus.
SUB_AGENT_MODEL=claude-sonnet-4-6
SUB_AGENT_MAX_TOKENS=4096
SUB_AGENT_MAX_ITERATIONS=16
SKILLS_DIR=../skills

# --- Persistence ------------------------------------------------------------
MEMORY_DIR=./.memory
MEMORY_SEED_DIR=./seed/memory
# missing | overwrite | skip
MEMORY_SEED_MODE=missing

# --- Knowledge graph (Postgres + pgvector) ----------------------------------
# When DATABASE_URL is set, the middleware persists the knowledge + agentic
# graph in Postgres (schema auto-migrates on startup), and the routines +
# verifier-store features come online. Leave empty to fall back to the
# in-memory store (tests + zero-config dev).
#
# When you run the full docker-compose stack, this value is overridden to
# `postgresql://omadia:omadia@postgres:5432/omadia` so the middleware
# reaches the in-network Postgres + pgvector service. The default below is
# the matching localhost URL for running `npm run dev` outside compose.
DATABASE_URL=postgresql://omadia:omadia@localhost:5432/omadia
# Optional — tag every node/edge with a tenant scope. Default: `default`.
GRAPH_TENANT_ID=default

# --- Admin endpoint (optional) ----------------------------------------------
# When set, mounts /api/admin for memory inspection/maintenance.
ADMIN_TOKEN=

# --- Dev endpoints (LOCAL ONLY) ---------------------------------------------
# Mounts unauthenticated /api/dev/graph + /api/dev/memory for the Graph +
# Memory viewers in the admin UI. Off by default — these routes expose raw
# memory + KG state without auth, so a fresh clone that gets reused as a
# starting point for a non-local deploy stays safe. Uncomment when you want
# the admin Graph/Memory tabs against your local middleware (the loopback-
# only docker-compose stack also reads this variable). NEVER set this on a
# public deployment.
# DEV_ENDPOINTS_ENABLED=true

# --- Runtime ----------------------------------------------------------------
MAX_TOOL_ITERATIONS=12
PORT=8080

# --- Diagram rendering (Kroki + S3-compatible storage) ----------------------
# When all of KROKI_BASE_URL, DIAGRAM_URL_SECRET, BUCKET_NAME and
# AWS_ENDPOINT_URL_S3 are set, the orchestrator exposes the `render_diagram`
# tool and the middleware serves signed PNG URLs at /diagrams/<key>.
# Defaults below match `docker-compose.yaml` in the repo root (local dev).
KROKI_BASE_URL=http://localhost:8765
# openssl rand -hex 32   (32+ random bytes; never share; rotate on leak)
DIAGRAM_URL_SECRET=
# Public base URL signed image URLs are issued under. For local dev this is
# the middleware on :8080.
DIAGRAM_PUBLIC_BASE_URL=http://localhost:8080

# Object-storage credentials. Locally filled by docker-compose.yaml's MinIO.
BUCKET_NAME=diagrams
AWS_ENDPOINT_URL_S3=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# --- Topic detection (Ollama sidecar for in-tenant embeddings) --------------
# When OLLAMA_BASE_URL is set, the orchestrator classifies follow-ups to
# decide "same topic / new topic / ask the user". docker-compose.yaml
# provides the local sidecar on :11434.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
TOPIC_CLASSIFIER_MODEL=claude-haiku-4-5
# Similarity thresholds — tune carefully. Above upper = auto continue,
# below lower = auto reset, in-between = escalate to a classifier turn.
TOPIC_UPPER_THRESHOLD=0.55
TOPIC_LOWER_THRESHOLD=0.15

# --- Vault (encrypted secrets store) ----------------------------------------
# Master key used to AES-256-GCM-encrypt plugin secrets at rest under
# /data/vault. Generate once with `openssl rand -base64 32` and keep stable
# across deployments — losing it makes vault entries unrecoverable.
#
# Leave empty to let the middleware auto-generate a key in /data/.dev-vault.key
# (DEV ONLY — the compose stack pins NODE_ENV=development so this path is
# available out of the box). The shipped image bakes NODE_ENV=production
# and refuses to boot without VAULT_KEY set; any production deployment
# (Fly, K8s, bare VM) MUST supply this as a secret before first boot.
VAULT_KEY=
