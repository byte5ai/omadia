# ----------------------------------------------------------------------------
# Omadia middleware configuration
# Copy to `.env` and fill in the values you need.
#
# Channel-, integration-, and agent-specific credentials (e.g. Odoo, Teams,
# Confluence) live inside their plugin packages and are configured through
# the admin UI's plugin setup form — NOT here.
# ----------------------------------------------------------------------------

# --- Anthropic SDK (OPTIONAL — see /setup wizard) ---------------------------
# Since OB-61 the Anthropic key is collected through the first-user setup
# wizard on first boot and stored encrypted in the per-plugin vault (one
# slot each for orchestrator, orchestrator-extras, verifier). The ENV var
# below is still honoured for backwards compatibility — when set on a
# cold boot, the bootstrap migrates it into the vault and then ignores it
# on subsequent boots. New deployments should leave this blank and run
# /setup instead. Rotate later via Admin → Runtime → Secrets (not via
# fly secrets).
# ANTHROPIC_API_KEY=sk-ant-...
ORCHESTRATOR_MODEL=claude-opus-4-8
ORCHESTRATOR_MAX_TOKENS=4096

# --- Per-turn model routing (Haiku triage) ----------------------------------
# When ON, a cheap Haiku classifier picks the model per turn: simple turns run
# on the simple model (default sonnet-4-6), complex turns on the complex model
# (default = ORCHESTRATOR_MODEL). Seeded into the orchestrator plugin config on
# first boot; afterwards toggle it live via Admin → Konfiguration. The *_MODEL
# overrides are optional — leave unset to use the defaults.
ORCHESTRATOR_MODEL_ROUTING=true
# MODEL_ROUTING_CLASSIFIER_MODEL=claude-haiku-4-5
# MODEL_ROUTING_SIMPLE_MODEL=claude-sonnet-4-6
# MODEL_ROUTING_COMPLEX_MODEL=claude-opus-4-8

# --- Sub-agent runtime ------------------------------------------------------
# Sub-agents run as local tool-loops in this process. Set SUB_AGENT_MODEL to
# a cheaper model (e.g. claude-sonnet-4-6 or claude-haiku-4-5) to keep costs
# down while the orchestrator stays on Opus.
SUB_AGENT_MODEL=claude-sonnet-4-6
SUB_AGENT_MAX_TOKENS=4096
SUB_AGENT_MAX_ITERATIONS=16
SKILLS_DIR=../skills

# --- Persistence ------------------------------------------------------------
# Memory backend: postgres (when DATABASE_URL is set, the default) persists in
# the knowledge-graph Postgres; inmemory (no DB) is RAM-only and resets on
# restart. There is no on-disk memory store. Override with MEMORY_BACKEND=
# postgres|inmemory only to force a choice; unset auto-derives from DATABASE_URL.
#
# UPLOADED_PACKAGES_DIR: leave UNSET in any Docker/Fly deployment — when
# PLATFORM_DATA_DIR is set (e.g. /data on a volume) it defaults UNDER it so
# uploaded plugins survive `docker compose up --build`. Setting it explicitly
# pins it to the image layer, which gets wiped on every rebuild.
MEMORY_SEED_DIR=./seed/memory
# missing | overwrite | skip
MEMORY_SEED_MODE=missing

# --- Knowledge graph (Postgres + pgvector) ----------------------------------
# When DATABASE_URL is set, the middleware persists the knowledge + agentic
# graph in Postgres (schema auto-migrates on startup), and the routines +
# verifier-store features come online. Leave empty to fall back to the
# in-memory store (tests + zero-config dev).
#
# When you run the full docker-compose stack, this value is overridden to
# `postgresql://omadia:omadia@postgres:5432/omadia` so the middleware
# reaches the in-network Postgres + pgvector service. The default below is
# the matching localhost URL for running `npm run dev` outside compose.
DATABASE_URL=postgresql://omadia:omadia@localhost:5432/omadia
# Optional — tag every node/edge with a tenant scope. Default: `default`.
GRAPH_TENANT_ID=default

# --- Admin endpoint (optional) ----------------------------------------------
# When set, mounts /api/admin for memory inspection/maintenance.
ADMIN_TOKEN=

# --- Dev endpoints (LOCAL ONLY) ---------------------------------------------
# Mounts unauthenticated /api/dev/graph + /api/dev/memory for the Graph +
# Memory viewers in the admin UI. Off by default — these routes expose raw
# memory + KG state without auth, so a fresh clone that gets reused as a
# starting point for a non-local deploy stays safe. Uncomment when you want
# the admin Graph/Memory tabs against your local middleware (the loopback-
# only docker-compose stack also reads this variable). NEVER set this on a
# public deployment.
# DEV_ENDPOINTS_ENABLED=true

# --- Runtime ----------------------------------------------------------------
MAX_TOOL_ITERATIONS=12
PORT=8080

# --- Diagram rendering (Kroki + S3-compatible storage) — OPTIONAL -----------
# Diagrams are OFF by default. The plugin activates only when KROKI_BASE_URL,
# DIAGRAM_URL_SECRET, BUCKET_NAME and AWS_ENDPOINT_URL_S3 are all set; then the
# orchestrator exposes the `render_diagram` tool and serves signed PNG URLs at
# /diagrams/<key>.
#   With Docker: enable via the compose overlays (docker-compose.storage.yaml +
#   docker-compose.diagrams.yaml). They set KROKI_BASE_URL / BUCKET_NAME / AWS_*
#   to the in-network service names for you — the only value you set HERE is the
#   signing secret below.
#   Bare-metal `npm run dev`: also uncomment KROKI_BASE_URL + the object-storage
#   block below and point them at your local services.
# KROKI_BASE_URL=http://localhost:8765
# openssl rand -hex 32   (32+ random bytes; never share; rotate on leak)
DIAGRAM_URL_SECRET=
# Public base URL signed image URLs are issued under. For local dev this is
# the middleware on :8080.
DIAGRAM_PUBLIC_BASE_URL=http://localhost:8080

# --- Plugin credential flows (spec 004) -------------------------------------
# Browser-facing origin that plugin OAuth/credential flow callbacks resolve
# against (ctx.flows.publicUrl). Defaults to PUBLIC_BASE_URL — set this only
# when flow callbacks must land on a different origin than the admin UI (rare).
# FLOW_PUBLIC_BASE_URL=https://omadia.example.com

# --- In-app "Create Issue" button (operator GitHub device flow) -------------
# Lets an operator connect their OWN GitHub account and file issues to the
# public repo (byte5ai/omadia) as themselves. Uses GitHub's DEVICE FLOW, so
# only a PUBLIC client id is needed — there is NO client secret. The client
# id is normally baked into the product (issues/githubOAuthProvider.ts:
# DEFAULT_GITHUB_CLIENT_ID); set this var only to OVERRIDE it per deployment.
#
# To enable: register a GitHub OAuth App (Settings > Developer settings >
# OAuth Apps), tick "Enable Device Flow", and use scope `public_repo`. No
# callback URL is required for the device flow.
# GITHUB_OAUTH_CLIENT_ID=Ov23lixxxxxxxxxxxxxx

# Object-storage credentials — OPTIONAL (chat attachments + diagrams/office).
# OFF by default. With Docker, docker-compose.storage.yaml sets these to the
# in-network MinIO for you. For bare-metal dev, uncomment and point at your
# S3/MinIO. (Leave commented for the minimal Docker core, otherwise the kernel
# wires an object store it can't reach from inside the container.)
# BUCKET_NAME=diagrams
# AWS_ENDPOINT_URL_S3=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# --- Topic detection (Ollama sidecar for in-tenant embeddings) — OPTIONAL ---
# Embeddings are OFF by default (the KG runs FTS-only, no topic detection).
# When OLLAMA_BASE_URL is set, the orchestrator also classifies follow-ups to
# decide "same topic / new topic / ask the user".
#   With Docker: enable via docker-compose.embeddings.yaml (it sets
#   OLLAMA_BASE_URL to the in-network sidecar for you).
#   Bare-metal dev: uncomment the two lines below.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
TOPIC_CLASSIFIER_MODEL=claude-haiku-4-5
# Similarity thresholds — tune carefully. Above upper = auto continue,
# below lower = auto reset, in-between = escalate to a classifier turn.
TOPIC_UPPER_THRESHOLD=0.55
TOPIC_LOWER_THRESHOLD=0.15

# --- Plugin code scanning (SkillSpector sidecar, issue #453) — OPTIONAL -----
# Advisory static scan of every ingested plugin package (upload, hub install,
# Builder install). OFF by default: without SKILLSPECTOR_URL nothing scans,
# installs behave unchanged, and NO verdict rows are written (store pages
# show no badge); `scan_failed` is reserved for real sidecar failures. A
# verdict NEVER blocks an install in v1 — it decorates the store detail page.
#   With Docker: enable via docker-compose.skillspector.yaml (it builds
#   middleware/sidecars/skillspector and sets the URL for you).
#   Bare-metal dev: run the sidecar yourself and uncomment below.
# SKILLSPECTOR_URL=http://localhost:8811
# SKILLSPECTOR_TIMEOUT_MS=20000

# --- Prompt-PII C1 detector (GLiNER sidecar, issue #361) — OPTIONAL ---------
# Transformer-based multilingual PII detection (person names, free-form
# addresses) for the privacy-guard `mask_user_prompt` feature — the C1 tier
# on top of the C0 regex baseline. OFF by default: without this URL no C1
# call is attempted and prompt masking (itself default-off) runs C0-only.
# Sidecar unreachable at runtime => audited degrade to C0
# (`promptMaskDegraded`) — never a silent unmasked pass-through. The sidecar
# receives raw prompt PII: keep it internal-network-only, never public.
#   With Docker: enable via docker-compose.pii-detector.yaml (it builds
#   middleware/sidecars/pii-detector and sets the URL for you).
#   Bare-metal dev: run the sidecar yourself and uncomment below.
# PRIVACY_C1_DETECTOR_URL=http://localhost:8812

# --- Vault (encrypted secrets store) ----------------------------------------
# Master key used to AES-256-GCM-encrypt plugin secrets at rest under
# /data/vault. Generate once with `openssl rand -base64 32` and keep stable
# across deployments — losing it makes vault entries unrecoverable.
#
# Leave empty to let the middleware auto-generate a key in /data/.dev-vault.key
# (DEV ONLY — the compose stack pins NODE_ENV=development so this path is
# available out of the box). The shipped image bakes NODE_ENV=production
# and refuses to boot without VAULT_KEY set; any production deployment
# (Fly, K8s, bare VM) MUST supply this as a secret before first boot.
VAULT_KEY=

# --- Dev platform (epic #470 W0) --------------------------------------------
# Isolated per-job code runners: clone a repo read-only, drive the headless
# Claude CLI over untrusted repo content, upload a diff, and open a PR from it
# server-side (the runner never holds a write token and never pushes). DARK BY
# DEFAULT — with DEV_PLATFORM_ENABLED unset nothing mounts and no worker runs.
# Requires a Postgres graphPool (DATABASE_URL); the durable job spine lives in
# dev_jobs/dev_repos/dev_job_events/dev_job_artifacts (migration 0022).
DEV_PLATFORM_ENABLED=false
# W0 walking-skeleton local backend. Runs the agent under a dedicated
# unprivileged uid with an allowlist-built env and NO dependency install / test
# execution — an unsafe skeleton by construction. Boot REFUSES the flag without
# DEV_PLATFORM_LOCAL_UID. Prefer the W1 container backend for anything real.
DEV_PLATFORM_UNSAFE_LOCAL=false
# DEV_PLATFORM_LOCAL_UID=          # required when DEV_PLATFORM_UNSAFE_LOCAL=true (positive, never 0/root)
# DEV_PLATFORM_WORKSPACE_DIR=      # default: <os.tmpdir()>/omadia-dev-jobs
# DEV_PLATFORM_RUNNER_BASE_URL=    # where the runner phones home; default http://127.0.0.1:<PORT>
DEV_PLATFORM_CLI_BIN=claude
DEV_PLATFORM_JOB_WALL_CLOCK_MS=1800000
DEV_PLATFORM_HEARTBEAT_TIMEOUT_MS=120000
DEV_PLATFORM_MAX_CONCURRENT_JOBS=1
# DEV_PLATFORM_GITHUB_CLIENT_ID=   # device-flow onboarding override
DEV_PLATFORM_COMMIT_AUTHOR=omadia-dev <dev-platform@omadia.ai>
DEV_PLATFORM_EVENT_RETENTION_DAYS=30
# Q4 decision: subscription-mode jobs run the CLI on the operator's Claude login,
# so the credential is INSIDE the runner. Off by default; boot REFUSES the flag
# unless DEV_PLATFORM_SUBSCRIPTION_ACK is also set.
DEV_PLATFORM_SUBSCRIPTION_MODE=false
# DEV_PLATFORM_SUBSCRIPTION_ACK=   # required acknowledgment string when SUBSCRIPTION_MODE=true
