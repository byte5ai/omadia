{
  "type": "lumen", "id": "counter",
  "state": { "count": { "type": "int", "min": 0, "init": 0 } },
  "transitions": { "inc": { "set": { "count": { "+": [ { "state": "count" }, { "lit": 1 } ] } } } },
  "view": { "lit": { "type": "text", "content": "tap to count" } },
  "events": [ { "on": "tap", "run": "inc" } ]
}
