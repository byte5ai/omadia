# URL of the middleware. The UI rewrites /bot-api/* to this host's /api/*.
# Only used at build/dev time by next.config.ts — no secrets live here.
#
# Default: middleware exposed on host port 8080 (matches middleware/.env.example
# PORT=8080 and docker-compose.yaml port-publish).
# For docker-compose, the value is overridden to `http://middleware:8080`
# (in-network service-DNS) — see docker-compose.yaml.
MIDDLEWARE_URL=http://localhost:8080
